# Step 1: Use Python base image
FROM python:3.8-slim

# Step 2: Set working directory
WORKDIR /app

# Step 3: Copy the application files (FastAPI app and models) into the container
COPY . /app

# Step 4: Install required dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Step 5: Expose port 8000 (FastAPI default)
EXPOSE 8000

# Step 6: Command to run FastAPI app with Gunicorn
CMD ["gunicorn", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "app_cnn:app", "--host", "0.0.0.0", "--port", "8000"]